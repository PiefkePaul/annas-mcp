# Optional default for fast book/article downloads when the client does not pass `secret_key`.
ANNAS_SECRET_KEY=
# Optional for local CLI use or other server-side disk writes. Not required for inline MCP downloads.
ANNAS_DOWNLOAD_PATH=
# Optional legacy single-mirror override.
ANNAS_BASE_URL=
# Optional comma-separated mirror list. Defaults to the current official mirrors.
ANNAS_BASE_URLS=annas-archive.gl,annas-archive.pk,annas-archive.gd
# Maximum file size returned inline through MCP as an embedded resource.
ANNAS_MAX_INLINE_DOWNLOAD_MB=20

ANNAS_HTTP_PORT=8080
ANNAS_HTTP_ADDR=:8080
ANNAS_HTTP_PATH=/mcp
# Use `none` for direct ChatGPT MCP connections. Use `bearer` only for non-ChatGPT clients.
ANNAS_HTTP_AUTH_MODE=none
# Optional. Used to advertise the final public MCP URL in the root endpoint.
ANNAS_PUBLIC_BASE_URL=https://annas-mcp.example.com
# Only for non-ChatGPT clients when ANNAS_HTTP_AUTH_MODE=bearer.
ANNAS_HTTP_BEARER_TOKEN=
