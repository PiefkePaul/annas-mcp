# Optional default for fast book/article downloads when the client does not pass `secret_key`.
ANNAS_SECRET_KEY=
# Optional for local CLI use or other server-side disk writes. Not required for inline MCP downloads.
ANNAS_DOWNLOAD_PATH=
# Optional legacy single-mirror override.
ANNAS_BASE_URL=
# Optional comma-separated mirror list. Defaults to the current official mirrors.
ANNAS_BASE_URLS=annas-archive.gl,annas-archive.pk,annas-archive.gd
# Maximum file size returned inline through MCP as an embedded resource.
ANNAS_MAX_INLINE_DOWNLOAD_MB=20

ANNAS_HTTP_ADDR=:8080
ANNAS_HTTP_PATH=/mcp
# Use `none` for public search-only use, `oauth` for per-user secure sign-in, or `bearer` for simple shared-token clients.
ANNAS_HTTP_AUTH_MODE=none
# Recommended for public deployments and effectively required for stable OAuth behind reverse proxies.
# Set this to the exact public origin used by ChatGPT/Claude, for example https://anna.example.com
# Do not include a path such as /mcp here.
ANNAS_PUBLIC_BASE_URL=https://annas-mcp.example.com
# Only for non-ChatGPT clients when ANNAS_HTTP_AUTH_MODE=bearer.
ANNAS_HTTP_BEARER_TOKEN=

# Required when ANNAS_HTTP_AUTH_MODE=oauth. Must decode to 32 bytes (base64, base64url, or hex).
ANNAS_AUTH_MASTER_KEY=
# Encrypted auth database path used for users, sessions, registered clients, and tokens.
ANNAS_AUTH_STORE_PATH=./annas-auth-store.enc
ANNAS_AUTH_ACCESS_TOKEN_TTL=1h
ANNAS_AUTH_REFRESH_TOKEN_TTL=720h
ANNAS_AUTH_CODE_TTL=10m
ANNAS_AUTH_SESSION_TTL=720h
