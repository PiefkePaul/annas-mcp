version: 2

before:
  hooks:
    - go test ./...

builds:
  - id: annas-mcp
    main: ./cmd/annas-mcp
    binary: annas-mcp
    ldflags:
      - >-
        -s -w
        -X github.com/PiefkePaul/annas-mcp/internal/version.Version={{.Version}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.Commit={{.Commit}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.Revision={{.ShortCommit}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.BuildDate={{.Date}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.BuiltBy=goreleaser
    env:
      - CGO_ENABLED=0
    goos:
      - linux
      - freebsd
      - darwin
    goarch:
      - amd64
      - arm64
      - arm
    goarm:
      - "7"
    ignore:
      - goos: freebsd
        goarch: arm64
      - goos: freebsd
        goarch: arm
      - goos: darwin
        goarch: arm

  - id: annas-mcp-win
    main: ./cmd/annas-mcp
    binary: annas-mcp
    ldflags:
      - >-
        -s -w
        -X github.com/PiefkePaul/annas-mcp/internal/version.Version={{.Version}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.Commit={{.Commit}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.Revision={{.ShortCommit}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.BuildDate={{.Date}}
        -X github.com/PiefkePaul/annas-mcp/internal/version.BuiltBy=goreleaser
    env:
      - CGO_ENABLED=0
    goos:
      - windows
    goarch:
      - amd64
      - arm64

archives:
  - name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    format: tar.xz
    format_overrides:
      - goos: windows
        format: zip
    wrap_in_directory: true
    files:
      - README.md

checksum:
  name_template: "{{ .ProjectName }}_{{ .Version }}--checksums.txt"

release:
  draft: false

changelog:
  sort: asc
